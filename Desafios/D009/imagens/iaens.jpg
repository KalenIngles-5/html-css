        { slotID: 'banner_materia1', slotName: adUnit, sizes: [[300, 250]] },
        { slotID: 'pub-in-text', slotName: adUnit, sizes: [[640, 360], [640, 480]] },
        { slotID: 'banner_materia2', slotName: adUnit, sizes: [[970, 90], [728, 90], [970, 250], [970, 150], [1190, 250]] },
        { slotID: 'banner_feed__0', slotName: adUnit, sizes: [[600, 300], [970, 250], [970, 90], [970, 150]] },
        { slotID: 'banner_middle_feed__1', slotName: adUnit, sizes: [[600, 300], [970, 250], [970, 90], [728, 90], [970, 150]] },
        { slotID: 'banner_feed__1', slotName: adUnit, sizes: [[600, 300], [970, 250], [970, 90], [970, 150]] },
      ]
    };
  }

  function fetchBids(adUnit, slots) {
    return new Promise((resolve) => {
      apstag.fetchBids({
        slots: slots,
        timeout: 2000
      }, function(bids) {
        requestAnimationFrame(() => {
          googletag.cmd.push(() => {
            apstag.setDisplayBids();
            resolve();
          });
        });
      });
    });
  }

  async function executeParallelAuctionAlongsidePrebid() {
    const adUnit = '85042905/' + utag_data.ad_unit;
    let slots;

    switch (utag_data.tipo_pagina) {
      case 'home':
        slots = window.location.pathname === "/"
          ? getSlotConfigs(adUnit).homeRoot
          : getSlotConfigs(adUnit).home;
        break;
      case 'topic':
        slots = getSlotConfigs(adUnit).topic;
        break;
      default:
        slots = getSlotConfigs(adUnit).default;
        break;
    }

    await fetchBids(adUnit, slots);
  }

  executeParallelAuctionAlongsidePrebid();
